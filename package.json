  "private": true,
  "scripts": {
    "dev:marketing": "pnpm --filter @ferro/marketing dev",
    "dev:admin": "pnpm --filter @ferro/admin dev",
    "build:marketing": "pnpm --filter @ferro/marketing build",
    "build:admin": "pnpm --filter @ferro/admin build",
